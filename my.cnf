[mysqld]
# --- Buffer Pool ---
innodb_buffer_pool_size = 512M

# --- Write Durability (trade safety for speed during LOAD DATA) ---
innodb_flush_log_at_trx_commit = 2
innodb_log_file_size = 256M

# --- I/O Throughput ---
innodb_io_capacity = 1000
innodb_io_capacity_max = 2000

# --- Bulk Insert ---
bulk_insert_buffer_size = 64M

# --- Connection Timeouts (avoid idle pooled connections being killed mid-import) ---
wait_timeout = 86400
interactive_timeout = 86400
net_read_timeout = 600
net_write_timeout = 600

# --- Sort / Join Buffers ---
sort_buffer_size = 4M
read_buffer_size = 2M
read_rnd_buffer_size = 4M

# --- Binary Log (disable if not used for replication) ---
# skip-log-bin
