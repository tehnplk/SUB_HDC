# ปรับสำหรับเครื่อง RAM 4 GB (MariaDB แชร์เครื่องกับ webapp/importer/sync)
# งบ MariaDB ~1.6 GB: buffer pool 1.2 GB + log/redo + per-connection buffers
# เหลือ ~2.4 GB ให้ OS + Node containers
[mysqld]
# --- Buffer Pool ---
# ก้อนหลักที่ cache index/data ของตารางใหญ่ (charge_opd ฯลฯ) เร่งทั้ง import และ query
innodb_buffer_pool_size = 1200M
innodb_buffer_pool_instances = 1

# --- Write Durability (trade safety for speed during LOAD DATA) ---
innodb_flush_log_at_trx_commit = 2
innodb_log_file_size = 256M
innodb_log_buffer_size = 16M

# --- I/O Throughput ---
innodb_io_capacity = 1000
innodb_io_capacity_max = 2000
innodb_flush_method = O_DIRECT

# --- Bulk Insert ---
bulk_insert_buffer_size = 32M

# --- Connections (แต่ละ connection กิน per-connection buffers; คุมไว้ไม่ให้บวม RAM) ---
max_connections = 60

# --- Connection Timeouts (avoid idle pooled connections being killed mid-import) ---
wait_timeout = 86400
interactive_timeout = 86400
# net_read_timeout ต้องยาวพอสำหรับ LOAD DATA แฟ้มใหญ่บนเครื่อง RAM น้อย (disk-bound):
# เดิม 600 วิ ตัด connection กลาง import chronicfu (365k แถว ใช้ ~619 วิ) จน mysql2
# โยน "connection is in closed state". ขยับเป็น 3600 วิ เผื่อ charge_opd (2.4M แถว) ด้วย
net_read_timeout = 3600
net_write_timeout = 3600

# --- Sort / Join Buffers (ต่อ connection — ตั้งเล็กเพราะคูณด้วย max_connections) ---
sort_buffer_size = 2M
read_buffer_size = 1M
read_rnd_buffer_size = 2M
join_buffer_size = 2M

# --- Temp tables (กัน spill ลง disk สำหรับ report/query ที่มี GROUP BY) ---
tmp_table_size = 32M
max_heap_table_size = 32M

# --- Binary Log (disable if not used for replication) ---
# skip-log-bin
